{
  "name": "aleph-hub",
  "version": "0.1.0",
  "private": true,
  "description": "Centralized extension catalog hub for Aleph — crawls, curates, and publishes a versioned static catalog of skills, plugins, and MCP servers.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "e2e": "playwright test",
    "pipeline": "tsx scripts/pipeline/index.ts",
    "validate:catalog": "tsx scripts/validate-catalog.ts"
  },
  "dependencies": {
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^29.1.1",
    "tsx": "^4.22.4",
    "typescript": "^5.7.0",
    "vitest": "^4.1.9"
  }
}
